# === Secrets — never commit ===
*.local
*.secret
.env
.env.*
*secret*
*token*
*credential*
*.key
*.pem
.zsh_local
.zshrc.local

# === Claude Code: only settings.json / commands are tracked ===
# Everything else under .claude is machine state / history / cache.
claude/.claude/*
!claude/.claude/settings.json
!claude/.claude/commands/
claude/.claude/settings.local.json

# === git: machine-local identity is never tracked ===
.gitconfig.local

# === karabiner: machine-generated backups ===
karabiner/.config/karabiner/automatic_backups/

# === macOS ===
.DS_Store
.AppleDouble
.LSOverride
Icon?

# === Editor ===
*.swp
*.swo
*~
.idea/
.vscode/
