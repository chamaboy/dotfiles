[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	autoSetupRemote = true
	default = current

[fetch]
	prune = true

[color]
	ui = auto

[core]
	editor = vim
	# Global ignore lives alongside this file (see ./ignore).
	excludesfile = ~/.config/git/ignore

[alias]
	st = status
	co = checkout
	br = branch
	lg = log --oneline --graph --decorate --all

# User identity (name/email) is machine-local — keep it out of the public repo.
# Put it in ~/.gitconfig.local:
#   [user]
#     name  = Your Name
#     email = you@example.com
[include]
	path = ~/.gitconfig.local
